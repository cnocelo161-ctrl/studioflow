STUDIOFLOW_HOST=127.0.0.1
STUDIOFLOW_PORT=5001
STUDIOFLOW_DEBUG=false
STUDIOFLOW_LOG_PATH=

# Auth (optional — leave both blank to disable; both must be set or both must be blank)
# Generate a password hash: .venv/bin/python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
STUDIOFLOW_AUTH_USER=
STUDIOFLOW_AUTH_PASSWORD_HASH=
